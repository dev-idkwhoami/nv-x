# Maintainer: Maximilian Oswald <maxi.osw@outlook.com>
pkgname=nv-vcam
pkgver=1.0.0
pkgrel=1
pkgdesc="Native NVIDIA Maxine virtual camera pipeline"
arch=('x86_64')
url="https://github.com/idkwhoami/nv-vcam"
license=('custom')
depends=(
  'gtk3'
  'webkit2gtk-4.1'
  'v4l2loopback-dkms'
)
makedepends=(
  'bun'
  'go'
  'gcc'
  'make'
  'wails'
)
source=()
sha256sums=()

_repo_root="$(realpath "$startdir/../..")"

build() {
  cd "$_repo_root"
  make build
}

package() {
  cd "$_repo_root"

  install -Dm0755 bin/nv-vcam "$pkgdir/usr/bin/nv-vcam"
  install -Dm0755 bin/nv-vcam-maxine-helper "$pkgdir/usr/bin/nv-vcam-maxine-helper"
  install -Dm0755 app/build/bin/nv-vcam-gui "$pkgdir/usr/bin/nv-vcam-gui"
  install -Dm0755 bin/nv-vcam-os-release-shim.so "$pkgdir/usr/lib/nv-vcam/nv-vcam-os-release-shim.so"

  install -Dm0644 app/build/linux/nv-vcam-gui.desktop "$pkgdir/usr/share/applications/nv-vcam-gui.desktop"
  install -Dm0644 app/build/linux-icon.png "$pkgdir/usr/share/icons/hicolor/256x256/apps/nv-vcam-gui.png"
}
